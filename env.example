# =============================================================================
# Hydra AI - Phase 1 Environment Variables
# Salin file ini menjadi .env dan sesuaikan nilainya.
# =============================================================================

# ---------------------------------------------------------------------------
# API Gateway (Port 8000)
# ---------------------------------------------------------------------------
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_DEBUG=false
API_GATEWAY_SAFETY_PIPELINE_URL=http://safety-pipeline:8002
API_GATEWAY_ORCHESTRATOR_URL=http://orchestrator:8001
API_GATEWAY_RATE_LIMIT_REQUESTS=60
API_GATEWAY_RATE_LIMIT_WINDOW=60
API_GATEWAY_API_KEY_HEADER=X-API-Key
API_GATEWAY_SESSION_HEADER=X-Session-Id
API_GATEWAY_REQUIRE_AUTH=false

# ---------------------------------------------------------------------------
# BFF Layer (Port 3000)
# ---------------------------------------------------------------------------
BFF_LAYER_HOST=0.0.0.0
BFF_LAYER_PORT=3000
BFF_LAYER_DEBUG=false
BFF_LAYER_API_GATEWAY_URL=http://api-gateway:8000

# ---------------------------------------------------------------------------
# Orchestrator Service (Port 8001)
# ---------------------------------------------------------------------------
ORCHESTRATOR_SERVICE_HOST=0.0.0.0
ORCHESTRATOR_SERVICE_PORT=8001
ORCHESTRATOR_SERVICE_DEBUG=false
ORCHESTRATOR_SERVICE_AI_SERVICE_URL=http://ai-service:8003
ORCHESTRATOR_SERVICE_MEMORY_SYSTEM_URL=http://memory-system:8006
ORCHESTRATOR_SERVICE_RESPONSE_SERVICE_URL=http://response-service:8005
ORCHESTRATOR_SERVICE_DEFAULT_TIMEOUT=30

# ---------------------------------------------------------------------------
# Safety Pipeline (Port 8002)
# ---------------------------------------------------------------------------
SAFETY_PIPELINE_HOST=0.0.0.0
SAFETY_PIPELINE_PORT=8002
SAFETY_PIPELINE_DEBUG=false
SAFETY_PIPELINE_TOXICITY_THRESHOLD=0.7

# ---------------------------------------------------------------------------
# AI Service (Port 8003)
# ---------------------------------------------------------------------------
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8003
AI_SERVICE_DEBUG=false
AI_SERVICE_MODEL_SERVICE_URL=http://model-service:8004
AI_SERVICE_SAFETY_PIPELINE_URL=http://safety-pipeline:8002

# ---------------------------------------------------------------------------
# Model Service (Port 8004)
# ---------------------------------------------------------------------------
MODEL_SERVICE_HOST=0.0.0.0
MODEL_SERVICE_PORT=8004
MODEL_SERVICE_DEBUG=false
MODEL_SERVICE_MODEL_ID=hydra-base
MODEL_SERVICE_MAX_TOKENS=1024
MODEL_SERVICE_TEMPERATURE=0.7
MODEL_SERVICE_INFERENCE_TIMEOUT=30

# ---------------------------------------------------------------------------
# Response Service (Port 8005)
# ---------------------------------------------------------------------------
RESPONSE_SERVICE_HOST=0.0.0.0
RESPONSE_SERVICE_PORT=8005
RESPONSE_SERVICE_DEBUG=false
RESPONSE_SERVICE_DEFAULT_FORMAT=json

# ---------------------------------------------------------------------------
# Memory System (Port 8006)
# ---------------------------------------------------------------------------
MEMORY_SYSTEM_HOST=0.0.0.0
MEMORY_SYSTEM_PORT=8006
MEMORY_SYSTEM_DEBUG=false
MEMORY_SYSTEM_DATABASE_URL=sqlite:///./data/memory.db
MEMORY_SYSTEM_MEMORY_TTL_HOURS=24
MEMORY_SYSTEM_SHORT_TERM_LIMIT=50
