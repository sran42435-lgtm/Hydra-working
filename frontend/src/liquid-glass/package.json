{
  "name": "@kyant/liquid-glass",
  "version": "1.0.0",
  "description": "Pixel-Perfect Native Shader Porting - Liquid Glass for Web. Cross-Platform Rendering Recreation with AGSL → GLSL/WebGL Shader Translation Pipeline",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js"
    },
    "./backdrops": {
      "types": "./dist/backdrops/index.d.ts",
      "import": "./dist/backdrops/index.mjs",
      "require": "./dist/backdrops/index.js"
    },
    "./effects": {
      "types": "./dist/effects/index.d.ts",
      "import": "./dist/effects/index.mjs",
      "require": "./dist/effects/index.js"
    },
    "./highlight": {
      "types": "./dist/highlight/index.d.ts",
      "import": "./dist/highlight/index.mjs",
      "require": "./dist/highlight/index.js"
    },
    "./shadow": {
      "types": "./dist/shadow/index.d.ts",
      "import": "./dist/shadow/index.mjs",
      "require": "./dist/shadow/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && rollup -c",
    "dev": "tsc --watch",
    "lint": "eslint src/ --ext .ts",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "liquid-glass",
    "glassmorphism",
    "frosted-glass",
    "backdrop-filter",
    "shader",
    "webgl",
    "agl",
    "glsl",
    "sdf",
    "refraction",
    "chromatic-aberration",
    "blur",
    "highlight",
    "shadow",
    "ios-style",
    "kyant",
    "pixel-perfect",
    "shader-porting"
  ],
  "author": {
    "name": "Kyant",
    "url": "https://github.com/kyant"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kyant/liquid-glass-web"
  },
  "bugs": {
    "url": "https://github.com/kyant/liquid-glass-web/issues"
  },
  "homepage": "https://github.com/kyant/liquid-glass-web#readme",
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "typescript": "^5.3.0",
    "rollup": "^4.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "rollup-plugin-terser": "^7.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Safari versions",
    "last 2 Firefox versions",
    "last 2 Edge versions"
  ]
}
