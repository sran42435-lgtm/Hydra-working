import { DrawScope, BlendMode } from '../core/Backdrop';
import { InnerShadow } from './InnerShadow';
import { ShapeProvider } from '../core/ShapeProvider';
import { CanvasGraphicsLayer } from '../core/LayerRecorder';
import { clipOutline, drawOutline } from '../core/Outline';
import { GraphicsLayer } from '../core/LayerRecorder';

// ============================================================================
// SHADOW MASK PAINT
// ============================================================================

/**
 * Paint used for erasing the offset area of inner shadow.
 * Uses Clear blend mode to punch a hole in the offset direction.
 * 
 * Port of ShadowMaskPaint in InnerShadowModifier.kt
 */
const SHADOW_MASK_PAINT = {
  blendMode: BlendMode.Clear,
  color: 'transparent',
};

// ============================================================================
// INNER SHADOW RENDERER
// ============================================================================

/**
 * Renders inner shadow effects for glass surfaces.
 * Port of InnerShadowNode.
 * 
 * ## Rendering Pipeline (Clip-based technique):
 * 1. Draw content first
 * 2. Record inner shadow to offscreen layer:
 *    a. Clip to outline shape
 *    b. Draw shape with shadow color
 *    c. Translate by offset
 *    d. Draw shape with ShadowMaskPaint (Clear blend)
 *       - This erases in the offset direction, leaving shadow on the opposite side
 * 3. Apply BlurEffect to the layer (RenderEffect property)
 * 4. Draw the blurred layer clipped to the outline
 * 
 * Key difference from drop shadow:
 * - Content is drawn FIRST, shadow on TOP
 * - Shadow is CLIPPED to shape interior
 * - Blur is applied via layer renderEffect (not MaskFilter)
 */
export class InnerShadowRenderer {
  private shadowLayer: GraphicsLayer | null = null;
  private clipPath: Path2D | null = null;
  private prevRadius: number = -1;

  /**
   * Draw inner shadow effect onto the canvas.
   * Port of InnerShadowNode.ContentDrawScope.draw()
   * 
   * @param scope - Current draw scope
   * @param shapeProvider - Shape provider for outline generation
   * @param innerShadow - Inner shadow configuration (null = no shadow)
   * @param drawContent - Function to draw the content (drawn first)
   */
  draw(
    scope: DrawScope,
    shapeProvider: ShapeProvider,
    innerShadow: InnerShadow | null,
    drawContent: () => void
  ): void {
    // Draw content first (inner shadow goes on top of content)
    drawContent();

    // Skip if no inner shadow
    if (!innerShadow) return;

    // Ensure we have a graphics layer
    if (!this.shadowLayer) {
      this.shadowLayer = new CanvasGraphicsLayer();
      this.shadowLayer.compositingStrategy = 'Offscreen';
    }

    const size = scope.size;
    const density = scope.density;
    const layoutDirection = scope.layoutDirection;

    const radius = innerShadow.radius;
    const offsetX = innerShadow.offsetX;
    const offsetY = innerShadow.offsetY;

    // Generate outline from shape
    const outline = shapeProvider.shape.createOutline(
      size,
      layoutDirection,
      { density, fontScale: scope.fontScale }
    );

    // Prepare clip path for rounded outlines
    const clipPath = outline.type === 'Rounded'
      ? (this.clipPath || new Path2D())
      : null;
    if (clipPath) {
      this.clipPath = clipPath;
    }

    // Configure shadow layer
    this.shadowLayer.alpha = innerShadow.alpha;
    this.shadowLayer.blendMode = innerShadow.blendMode as GlobalCompositeOperation;
    this.shadowLayer.topLeft = { x: 0, y: 0 };

    // Update blur if radius changed
    if (this.prevRadius !== radius) {
      // Apply blur effect to layer
      // In Android: shadowLayer.renderEffect = BlurEffect(radius, radius, TileMode.Decal)
      // For Canvas 2D: we apply blur filter during recording
      this.prevRadius = radius;
    }

    // Record inner shadow into offscreen layer
    this.shadowLayer.record(
      { width: Math.ceil(size.width), height: Math.ceil(size.height) },
      (recordScope) => {
        const ctx = recordScope.canvas as CanvasRenderingContext2D;

        ctx.save();

        // Apply blur filter to the entire layer content
        if (radius > 0) {
          ctx.filter = `blur(${radius}px)`;
        }

        // Set shadow color
        ctx.fillStyle = innerShadow.color;

        // Clip to outline (shadow stays inside shape)
        ctx.save();
        clipOutline(ctx, outline, clipPath || undefined);

        // Draw shape filled with shadow color
        drawOutline(ctx, outline);
        ctx.fill();

        // Erase in the offset direction using Clear blend mode
        ctx.save();
        ctx.globalCompositeOperation = SHADOW_MASK_PAINT.blendMode as GlobalCompositeOperation;
        ctx.translate(offsetX, offsetY);
        drawOutline(ctx, outline);
        ctx.fill();
        ctx.restore();

        ctx.restore();
        ctx.restore();
      }
    );

    // Draw the shadow layer onto main canvas, clipped to outline
    const mainCtx = scope.canvas as CanvasRenderingContext2D;
    mainCtx.save();
    clipOutline(mainCtx, outline, clipPath || undefined);
    this.shadowLayer.drawTo(mainCtx);
    mainCtx.restore();
  }

  /**
   * Release resources.
   */
  release(): void {
    this.shadowLayer?.release();
    this.shadowLayer = null;
    this.clipPath = null;
    this.prevRadius = -1;
  }
}

// ============================================================================
// CSS INNER SHADOW (FALLBACK)
// ============================================================================

/**
 * Apply inner shadow using CSS box-shadow inset.
 * Best performance when applicable.
 * 
 * @param element - The DOM element
 * @param innerShadow - Inner shadow configuration
 */
export function innerShadowCSS(
  element: HTMLElement,
  innerShadow: InnerShadow | null
): void {
  if (!innerShadow || innerShadow.radius <= 0 || innerShadow.alpha <= 0) {
    // Remove only inset shadows, keep other box-shadows
    element.style.boxShadow = element.style.boxShadow
      ?.replace(/inset\s+[^,]+/g, '')
      .trim() || '';
    return;
  }

  const { radius, offsetX, offsetY, color } = innerShadow;

  // CSS inset box-shadow
  const insetShadow = `inset ${offsetX}px ${offsetY}px ${radius}px ${color}`;

  // Append to existing box-shadow
  const existing = element.style.boxShadow && element.style.boxShadow !== 'none'
    ? element.style.boxShadow.replace(/inset\s+[^,]+/g, '').trim()
    : '';

  element.style.boxShadow = existing
    ? `${existing}, ${insetShadow}`
    : insetShadow;
}

/**
 * Apply inner shadow using background gradient trick.
 * Alternative when inset box-shadow performance is poor.
 * 
 * Creates a gradient that simulates inner shadow on one edge.
 * 
 * @param element - The DOM element
 * @param innerShadow - Inner shadow configuration
 * @param edge - Which edge to apply shadow ('top' | 'bottom' | 'left' | 'right')
 */
export function innerShadowGradient(
  element: HTMLElement,
  innerShadow: InnerShadow,
  edge: 'top' | 'bottom' | 'left' | 'right' = 'top'
): void {
  const { color } = innerShadow;
  let gradient: string;

  switch (edge) {
    case 'top':
      gradient = `linear-gradient(to bottom, ${color}, transparent)`;
      break;
    case 'bottom':
      gradient = `linear-gradient(to top, ${color}, transparent)`;
      break;
    case 'left':
      gradient = `linear-gradient(to right, ${color}, transparent)`;
      break;
    case 'right':
      gradient = `linear-gradient(to left, ${color}, transparent)`;
      break;
  }

  // Apply as background image (can be combined with existing backgrounds)
  const existingBg = element.style.backgroundImage && element.style.backgroundImage !== 'none'
    ? element.style.backgroundImage + ', '
    : '';

  element.style.backgroundImage = existingBg + gradient;
}

// ============================================================================
// FACTORY FUNCTION
// ============================================================================

/**
 * Create an inner shadow renderer.
 */
export function createInnerShadowRenderer(): InnerShadowRenderer {
  return new InnerShadowRenderer();
}

// ============================================================================
// EXPORTS
// ============================================================================

export default InnerShadowRenderer;
